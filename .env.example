POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=freqtrade_ai
POSTGRES_USER=freqtrade
POSTGRES_PASSWORD=change_me
DATABASE_URL=postgresql+psycopg://freqtrade:change_me@localhost:5432/freqtrade_ai
# Use the one existing local Freqtrade installation. Keep the real absolute
# path in your local shell or .env; do not create a second project copy.
FREQTRADE_BINARY=/absolute/path/to/freqtrade_venv/bin/freqtrade

OKX_DEMO_API_KEY=change_me
OKX_DEMO_API_SECRET=change_me
OKX_DEMO_API_PASSPHRASE=change_me

MIMO_API_KEY=change_me
OPENAI_API_KEY=change_me
DEEPSEEK_API_KEY=change_me

# Local write-operation authorization only. Keep the real value in local ENV;
# send it as X-Operator-Token and never persist it in frontend storage.
FREQTRADE_AI_OPERATOR_TOKEN=change_me

STRATEGY_BLUEPRINT_PROVIDER=fake
STRATEGY_BLUEPRINT_MODEL=gpt-4.1-mini
STRATEGY_BLUEPRINT_BASE_URL=https://api.openai.com/v1
STRATEGY_BLUEPRINT_API_KEY_ENV=OPENAI_API_KEY
STRATEGY_BLUEPRINT_TIMEOUT_SECONDS=30

# To test the real DeepSeek provider locally, keep the key only in your local
# environment and set:
# STRATEGY_BLUEPRINT_PROVIDER=deepseek
# STRATEGY_BLUEPRINT_MODEL=deepseek-v4-pro
# STRATEGY_BLUEPRINT_BASE_URL=https://api.deepseek.com
# STRATEGY_BLUEPRINT_API_KEY_ENV=DEEPSEEK_API_KEY
